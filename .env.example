# Anvaya MCP Server — Environment Variables
# Copy this file to .env and fill in real keys.
# The server works fully with mock/fallback data even without these keys.

# NewsAPI.org — free tier, ~100 req/day
# Sign up at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Agmarknet via data.gov.in — free, covers agricultural commodity prices
# Sign up at: https://data.gov.in/user/register
AGMARKNET_API_KEY=your_agmarknet_key_here

# Optional: Override OSRM demo server (defaults to router.project-osrm.org)
# OSRM_BASE_URL=http://router.project-osrm.org
